# Public canonical URL used for metadata, sitemap.xml, and robots.txt.
# Use your Vercel production domain or custom domain.
NEXT_PUBLIC_SITE_URL="https://global-trail-race-finder.vercel.app"

# Supabase project connection.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Server-only key used for admin review actions and database seeding.
# Never expose this in client components.
SUPABASE_SERVICE_ROLE_KEY=""

# Future admin auth placeholders. Not implemented yet.
# ADMIN_AUTH_ENABLED="false"
# ADMIN_ALLOWED_EMAILS=""

# Future ingestion controls. Importers do not run automatically in this MVP.
# INGESTION_USER_AGENT="GlobalTrailRaceFinderBot/0.1 (+https://global-trail-race-finder.vercel.app)"
# INGESTION_MIN_DELAY_MS="1500"
